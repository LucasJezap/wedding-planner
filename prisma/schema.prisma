generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GuestSide {
  BRIDE
  GROOM
  FAMILY
  FRIENDS
}

enum UserRole {
  ADMIN
  WITNESS
  READ_ONLY
}

enum RsvpStatus {
  PENDING
  ATTENDING
  DECLINED
}

enum PaymentCoverage {
  FULL
  HALF
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskAssignee {
  GROOM
  BRIDE
  COUPLE
  WITNESSES
}

enum VendorCategoryType {
  VENUE
  CATERING
  MUSIC
  PHOTO
  FLORAL
  WEDDING_PLANNER
  CONTENT_CREATOR
  MAKEUP
  HAIR
  PRIEST
  ATTIRE
  TRANSPORT
  OTHER
}

enum VendorStatus {
  RESEARCH
  CONTACTED
  OFFER_RECEIVED
  NEGOTIATING
  BOOKED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  weddingId    String
  email        String   @unique
  name         String
  role         UserRole @default(ADMIN)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  wedding      Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@map("users")
}

model UserInvitation {
  id         String   @id @default(cuid())
  weddingId  String   @map("wedding_id")
  email      String
  role       UserRole @default(WITNESS)
  token      String   @unique
  acceptedAt DateTime? @map("accepted_at")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([weddingId, email])
  @@map("user_invitations")
}

model Wedding {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String
  coupleOneName   String           @map("couple_one_name")
  coupleTwoName   String           @map("couple_two_name")
  venueName       String           @map("venue_name")
  venueAddress    String           @map("venue_address")
  ceremonyDate    DateTime         @map("ceremony_date")
  aboutText       String?          @map("about_text")
  dressCode       String?          @map("dress_code")
  faqItems        String?          @map("faq_items")
  parkingInfo     String?          @map("parking_info")
  accommodationInfo String?        @map("accommodation_info")
  registryInfo    String?          @map("registry_info")
  transportInfo   String?          @map("transport_info")
  coordinatorName String?          @map("coordinator_name")
  coordinatorPhone String?         @map("coordinator_phone")
  coordinatorEmail String?         @map("coordinator_email")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  users           User[]
  userInvitations UserInvitation[]
  invitationGroups InvitationGroup[]
  guests          Guest[]
  weddingTables   WeddingTable[]
  seats           Seat[]
  vendors         Vendor[]
  vendorCategories VendorCategory[]
  budgetCategories BudgetCategory[]
  expenses        Expense[]
  payments        Payment[]
  tasks           Task[]
  taskChecklistItems TaskChecklistItem[]
  timelineEvents  TimelineEvent[]
  contacts        Contact[]
  rsvps           Rsvp[]
  notes           Note[]

  @@map("weddings")
}

model InvitationGroup {
  id                String   @id @default(cuid())
  weddingId         String   @map("wedding_id")
  name              String
  invitedGuestCount Int      @default(1) @map("invited_guest_count")
  allowsPlusOne     Boolean  @default(false) @map("allows_plus_one")
  notes             String   @default("")
  sharedRsvpStatus  RsvpStatus @default(PENDING) @map("shared_rsvp_status")
  attendingChildren Int      @default(0) @map("attending_children")
  plusOneName       String   @default("") @map("plus_one_name")
  mealChoice        String   @default("") @map("meal_choice")
  dietaryNotes      String   @default("") @map("dietary_notes")
  needsAccommodation Boolean @default(false) @map("needs_accommodation")
  transportToVenue  Boolean  @default(false) @map("transport_to_venue")
  transportFromVenue Boolean @default(false) @map("transport_from_venue")
  message           String   @default("")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  wedding           Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests            Guest[]

  @@unique([weddingId, name])
  @@map("invitation_groups")
}

model Guest {
  id                  String        @id @default(cuid())
  weddingId           String        @map("wedding_id")
  firstName           String        @map("first_name")
  lastName            String        @map("last_name")
  side                GuestSide
  rsvpStatus          RsvpStatus    @default(PENDING) @map("rsvp_status")
  rsvpToken           String        @unique @map("rsvp_token")
  dietaryRestrictions String[]      @default([])
  paymentCoverage     PaymentCoverage @default(FULL) @map("payment_coverage")
  invitationReceived  Boolean       @default(false) @map("invitation_received")
  transportToVenue    Boolean       @default(false) @map("transport_to_venue")
  transportFromVenue  Boolean       @default(false) @map("transport_from_venue")
  invitationGroupId   String?       @map("invitation_group_id")
  tableId             String?       @map("table_id")
  groupName           String?       @map("group_name")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  wedding             Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  invitationGroup     InvitationGroup? @relation(fields: [invitationGroupId], references: [id])
  weddingTable        WeddingTable? @relation(fields: [tableId], references: [id])
  seat                Seat?
  contact             Contact?
  note                Note?
  rsvp                Rsvp?

  @@map("guests")
}

model WeddingTable {
  id         String   @id @default(cuid())
  weddingId  String   @map("wedding_id")
  name       String
  capacity   Int
  positionX  Int      @default(0) @map("position_x")
  positionY  Int      @default(0) @map("position_y")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests     Guest[]
  seats      Seat[]

  @@map("tables")
}

model Seat {
  id         String        @id @default(cuid())
  weddingId  String        @map("wedding_id")
  tableId    String        @map("table_id")
  guestId    String?       @unique @map("guest_id")
  label      String
  position   Int
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  wedding    Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  weddingTable WeddingTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest      Guest?        @relation(fields: [guestId], references: [id])

  @@map("seats")
}

model VendorCategory {
  id        String             @id @default(cuid())
  weddingId String             @map("wedding_id")
  name      String
  type      VendorCategoryType
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  wedding   Wedding            @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  vendors   Vendor[]

  @@map("vendor_categories")
}

model Vendor {
  id               String         @id @default(cuid())
  weddingId        String         @map("wedding_id")
  categoryId       String         @map("category_id")
  name             String
  cost             Decimal        @db.Decimal(10, 2)
  status           VendorStatus   @default(RESEARCH)
  owner            String         @default("")
  bookingDate      DateTime?      @map("booking_date")
  followUpDate     DateTime?      @map("follow_up_date")
  depositAmount    Decimal        @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  offerUrl         String         @default("") @map("offer_url")
  websiteUrl       String         @default("") @map("website_url")
  instagramUrl     String         @default("") @map("instagram_url")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  wedding          Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category         VendorCategory @relation(fields: [categoryId], references: [id])
  expenses         Expense[]
  contact          Contact?
  note             Note?

  @@map("vendors")
}

model BudgetCategory {
  id            String    @id @default(cuid())
  weddingId     String    @map("wedding_id")
  name          String
  plannedAmount Decimal   @db.Decimal(10, 2) @map("planned_amount")
  color         String    @default("#D89BAE")
  notes         String    @default("")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  wedding       Wedding   @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  expenses      Expense[]

  @@map("budget_categories")
}

model Expense {
  id          String         @id @default(cuid())
  weddingId   String         @map("wedding_id")
  categoryId  String         @map("category_id")
  vendorId    String?        @map("vendor_id")
  name        String
  estimateMin Decimal        @db.Decimal(10, 2) @map("estimate_min")
  estimateMax Decimal        @db.Decimal(10, 2) @map("estimate_max")
  actualAmount Decimal       @db.Decimal(10, 2) @map("actual_amount")
  dueDate     DateTime?      @map("due_date")
  notes       String         @default("")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  wedding     Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category    BudgetCategory @relation(fields: [categoryId], references: [id])
  vendor      Vendor?        @relation(fields: [vendorId], references: [id])
  payments    Payment[]

  @@map("expenses")
}

model Payment {
  id        String   @id @default(cuid())
  weddingId String   @map("wedding_id")
  expenseId String   @map("expense_id")
  amount    Decimal  @db.Decimal(10, 2)
  paidAt    DateTime @map("paid_at")
  notes     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Task {
  id          String       @id @default(cuid())
  weddingId   String       @map("wedding_id")
  title       String
  description String
  dueDate     DateTime     @map("due_date")
  priority    TaskPriority
  status      TaskStatus
  assignee    TaskAssignee @default(COUPLE)
  tags        String[]     @default([])
  blockedByTaskIds String[] @default([]) @map("blocked_by_task_ids")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  note        Note?
  checklistItems TaskChecklistItem[]

  @@map("tasks")
}

model TaskChecklistItem {
  id         String   @id @default(cuid())
  weddingId  String   @map("wedding_id")
  taskId     String   @map("task_id")
  title      String
  completed  Boolean  @default(false)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
  @@map("task_checklist_items")
}

model TimelineEvent {
  id          String   @id @default(cuid())
  weddingId   String   @map("wedding_id")
  title       String
  description String
  startsAt    DateTime @map("starts_at")
  location    String
  visibleToGuests Boolean @default(true) @map("visible_to_guests")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@map("timeline_events")
}

model Contact {
  id         String   @id @default(cuid())
  weddingId  String   @map("wedding_id")
  guestId    String?  @unique @map("guest_id")
  vendorId   String?  @unique @map("vendor_id")
  email      String
  phone      String
  guest      Guest?   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  vendor     Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("contacts")
}

model Rsvp {
  id         String     @id @default(cuid())
  weddingId  String     @map("wedding_id")
  guestId    String     @unique @map("guest_id")
  status     RsvpStatus
  guestCount Int        @default(1) @map("guest_count")
  attendingChildren Int @default(0) @map("attending_children")
  plusOneName String    @default("") @map("plus_one_name")
  mealChoice String     @default("") @map("meal_choice")
  dietaryNotes String   @default("") @map("dietary_notes")
  needsAccommodation Boolean @default(false) @map("needs_accommodation")
  transportToVenue Boolean @default(false) @map("transport_to_venue")
  transportFromVenue Boolean @default(false) @map("transport_from_venue")
  message    String     @default("")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  wedding    Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guest      Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@map("rsvps")
}

model Note {
  id         String   @id @default(cuid())
  weddingId  String   @map("wedding_id")
  guestId    String?  @unique @map("guest_id")
  vendorId   String?  @unique @map("vendor_id")
  taskId     String?  @unique @map("task_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guest      Guest?   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  vendor     Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("notes")
}
